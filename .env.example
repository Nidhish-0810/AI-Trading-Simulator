# ─────────────────────────────────────────────────────────────────────────────
# TradeAI — Environment Variables
# Copy to .env and fill in your values before running docker-compose
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_NAME=TradeAI

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=tradeai
POSTGRES_PASSWORD=tradeai_secret_2024
POSTGRES_DB=tradeai_db
DATABASE_URL=postgresql+asyncpg://tradeai:tradeai_secret_2024@postgres:5432/tradeai_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_2024
REDIS_URL=redis://:redis_secret_2024@redis:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# ── Trading ──────────────────────────────────────────────────────────────────
STARTING_BALANCE=100000.0
COMMISSION_RATE=0.001

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# ── Frontend (Vite build-time variables) ─────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=TradeAI
